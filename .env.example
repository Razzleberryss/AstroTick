# ==============================================================================
# Kalshi 15-Minute BTC Trader  -  Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ==============================================================================

# ── Kalshi API Credentials ────────────────────────────────────────────────────
# Get these from: https://kalshi.com/profile/api-management
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# ── Environment ───────────────────────────────────────────────────────────────
# Use 'demo' for paper trading (free, no real money)
# Use 'prod' for live real-money trading
KALSHI_ENV=demo

# ── Risk Settings ─────────────────────────────────────────────────────────────
# Max dollars to risk per single trade
MAX_TRADE_DOLLARS=10
# Max number of open positions at any time
MAX_OPEN_POSITIONS=3
# Max total dollars deployed across all open positions
MAX_TOTAL_EXPOSURE=50
# Allowed contract price range in cents (1-99)
MIN_CONTRACT_PRICE_CENTS=10
MAX_CONTRACT_PRICE_CENTS=90

# ── Strategy Settings ─────────────────────────────────────────────────────────
# Kalshi BTC 15-minute series ticker (check Kalshi for the exact value)
BTC_SERIES_TICKER=KXBTC
# yfinance BTC/USD symbol for spot price momentum
BTC_TICKER=BTC-USD
# Number of 1-minute bars to look back for momentum calculation
MOMENTUM_LOOKBACK_BARS=5
# Minimum signal confidence to place a trade (0.05 = 5%)
MIN_EDGE_THRESHOLD=0.05

# ── Bot Loop ──────────────────────────────────────────────────────────────────
# Seconds between each bot cycle (60 = once per minute)
POLL_INTERVAL_SECONDS=60
# Dry run mode: 'true' logs trades without placing them on the exchange
DRY_RUN=true

# ── Logging & Output ──────────────────────────────────────────────────────────
# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# CSV file to log all trade decisions
TRADE_LOG_FILE=trades.csv
