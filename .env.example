# ─── Kalshi API Credentials ───────────────────────────────────────────────────
# Get these from: https://kalshi.com/profile/api-management
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# ─── Environment ───────────────────────────────────────────────────────────────
# Use 'demo' for paper trading, 'prod' for real money
KALSHI_ENV=demo

# ─── Risk Settings ─────────────────────────────────────────────────────────────
# Max dollars to risk per single trade (in cents on Kalshi)
MAX_TRADE_DOLLARS=10
# Max number of open positions at once
MAX_OPEN_POSITIONS=3
# Max total dollars deployed at once
MAX_TOTAL_EXPOSURE=50
# Minimum edge required before placing a trade (0.05 = 5%)
MIN_EDGE_THRESHOLD=0.05

# ─── Strategy Settings ─────────────────────────────────────────────────────────
# Coinbase BTC/USD ticker (used for price momentum signal)
BTC_TICKER=BTC-USD
# How many seconds between each bot loop iteration
LOOP_INTERVAL_SECONDS=30
# Dry run mode: 'true' logs trades without placing them
DRY_RUN=true
